# Claude API
ANTHROPIC_API_KEY=your_key_here

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AdSense (opzionale, aggiungilo dopo approvazione)
ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# Google Analytics 4 (un measurement ID per sito, oppure uno globale)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# VPS paths
WWW_ROOT=/var/www
NODE_ENV=production

# Content settings
# Limite massimo assoluto articoli/giorno (il sistema scala automaticamente per età sito)
MAX_ARTICLES_PER_DAY=35
SITES_PER_WEEK=10

# Cloudflare (DNS automatico + CDN + SSL per ogni nuovo dominio)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# IP del VPS (usato da Cloudflare per creare il record A)
SERVER_IP=178.104.17.161

# SSL email (fallback Certbot se Cloudflare non è configurato)
CERTBOT_EMAIL=your@email.com

# Pexels API (immagini articoli e foto autori)
PEXELS_API_KEY=your_pexels_key_here
