# Claude API
ANTHROPIC_API_KEY=your_key_here

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AdSense (opzionale, aggiungilo dopo approvazione)
ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# Google Analytics 4 (un measurement ID per sito, oppure uno globale)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console — ottieni il token da: Search Console > Settings > Ownership verification > HTML tag
GOOGLE_SITE_VERIFICATION=

# VPS paths
WWW_ROOT=/var/www
NODE_ENV=production

# Content settings
# Limite massimo assoluto articoli/giorno (il sistema scala automaticamente per età sito)
MAX_ARTICLES_PER_DAY=35
SITES_PER_WEEK=10

# Cloudflare (DNS automatico + CDN + SSL per ogni nuovo dominio)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# IP del VPS (usato da Cloudflare per creare il record A)
SERVER_IP=178.104.17.161

# SSL email (fallback Certbot se Cloudflare non è configurato)
CERTBOT_EMAIL=your@email.com

# Pexels API (immagini articoli e foto autori)
PEXELS_API_KEY=your_pexels_key_here

# Disqus comments (opzionale — crea account su disqus.com, ottieni shortname del sito)
DISQUS_SHORTNAME=

# Ezoic (opzionale, alternativa AdSense con revenue sharing)
EZOIC_SITE_ID=

# ── Automazione avanzata ───────────────────────────────────────────────────────

# Email alerts — notifiche su errori critici e report settimanale
# Opzione 1: Resend (raccomandato) — gratuito 3000 email/mese su resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL_FROM=alerts@tuodominio.com   # deve essere un dominio verificato su Resend
ALERT_EMAIL_TO=tua@email.com

# Opzione 2: SMTP generico (Gmail, Mailgun, ecc.) — alternativa a Resend
# Per Gmail: abilita "App Password" in Account Google > Sicurezza
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tua@gmail.com
# SMTP_PASS=app-password-16-caratteri
# ALERT_EMAIL_FROM=tua@gmail.com
# ALERT_EMAIL_TO=tua@email.com

# AlsoAsked API — PAA questions (strutturate, affidabili)
# $9/mese per 500 ricerche — https://alsoasked.com
# Se assente, usa scraping Google come fallback (fragile)
ALSOASKED_API_KEY=

# SerpAPI — ranking tracker (controlla posizioni Google)
# 100 ricerche/mese gratuite su serpapi.com
SERPAPI_KEY=

# Google Search Console — Indexing API (auto-submit nuovi articoli)
# Crea Service Account in Google Cloud Console, scarica JSON credenziali
# Aggiungi email service account come Owner in GSC
GSC_SERVICE_ACCOUNT_JSON=/opt/content-network/gsc-service-account.json
