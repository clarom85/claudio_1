# Claude API
ANTHROPIC_API_KEY=your_key_here

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AdSense (opzionale, aggiungilo dopo approvazione)
ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# VPS paths
WWW_ROOT=/var/www
NODE_ENV=production

# Content settings
ARTICLES_PER_DAY=50
SITES_PER_WEEK=10

# SSL email (per certbot)
SSL_EMAIL=your@email.com
