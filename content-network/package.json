{
  "name": "content-network",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "keyword":    "node packages/keyword-engine/src/index.js",
    "content":    "node packages/content-engine/src/index.js",
    "authors":    "node scripts/generate-authors.js",
    "spawn":      "node packages/site-spawner/src/index.js",
    "schedule":   "node packages/scheduler/src/index.js",
    "db:migrate": "node packages/db/src/migrate.js",
    "email-api":  "node packages/email-api/src/index.js",
    "pm2:start":  "pm2 start ecosystem.config.js",
    "pm2:restart": "pm2 restart all",
    "pm2:stop":   "pm2 stop all",
    "pm2:logs":   "pm2 logs",
    "health":     "node packages/vps/src/health-check.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}
