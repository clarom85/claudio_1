---
import Base from '../layouts/Base.astro';

export async function getStaticPaths() {
  let articles = [];
  try {
    const { default: data } = await import('../content/articles.json', { assert: { type: 'json' } });
    articles = data;
  } catch {
    return [];
  }

  // Extract unique categories for static nav
  const categorySlugs = new Map();
  for (const a of articles) {
    if (a.category && !categorySlugs.has(a.category)) {
      categorySlugs.set(a.category, a.category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''));
    }
  }
  const navCategories = Array.from(categorySlugs.entries()).map(([name, slug]) => ({ name, slug }));

  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article, navCategories }
  }));
}

const { article, navCategories = [] } = Astro.props;
---
<Base
  title={article.title}
  description={article.metaDescription}
  slug={article.slug}
  schemas={article.schemas}
  ogImage={article.image || `/images/${article.slug}.webp`}
  lcpImage={article.image || `/images/${article.slug}.webp`}
  categories={navCategories}
>
  <div set:html={article.content} />

  <!-- Related articles loaded client-side via JS -->
  <script define:vars={{ slug: article.slug, tags: article.tags }}>
    fetch('/api/articles.json')
      .then(r => r.json())
      .then(all => {
        const related = all
          .filter(a => a.slug !== slug && a.tags?.some(t => tags?.includes(t)))
          .slice(0, 4);

        const container = document.getElementById('related-articles');
        if (!container || !related.length) return;

        container.innerHTML = related.map(a => `
          <article style="display:flex; gap:10px; margin-bottom:12px;">
            <img src="/images/${a.slug}.webp" alt="${a.title}"
              style="width:70px; height:52px; object-fit:cover; border-radius:3px; flex-shrink:0;"
              loading="lazy" onerror="this.src='/images/placeholder.webp'" />
            <div>
              <a href="/${a.slug}" style="font-size:13px; font-weight:600; color:#1a1a2e; text-decoration:none; line-height:1.4; display:block;">
                ${a.title}
              </a>
            </div>
          </article>
        `).join('');
      }).catch(() => {});
  </script>
</Base>
