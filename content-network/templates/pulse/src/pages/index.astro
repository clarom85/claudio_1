---
import Base from '../layouts/Base.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

const siteName = import.meta.env.SITE_NAME || 'The Daily Pulse';

// Leggi articoli generati
const articlesPath = join(process.cwd(), 'src/content/articles');
let articles = [];
try {
  const { default: articlesData } = await import('../content/articles.json', { assert: { type: 'json' } });
  articles = articlesData;
} catch {
  articles = [];
}

const heroArticle = articles[0];
const featuredArticles = articles.slice(1, 5);
const latestArticles = articles.slice(5, 20);

// Extract unique categories from articles for static nav
const categorySlugs = new Map();
for (const a of articles) {
  if (a.category && !categorySlugs.has(a.category)) {
    categorySlugs.set(a.category, a.category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''));
  }
}
const navCategories = Array.from(categorySlugs.entries()).map(([name, slug]) => ({ name, slug }));
---
<Base
  title={`${siteName} — Expert Guides & How-To Articles`}
  description={`${siteName}: Your trusted source for expert guides, practical advice, and in-depth how-to articles.`}
  categories={navCategories}
  lcpImage={heroArticle ? (heroArticle.image || `/images/${heroArticle.slug}.webp`) : undefined}
>
  <!-- Homepage Ad Leaderboard -->
  <div class="ad-unit ad-unit--leaderboard" style="margin-bottom: 24px;">
    <ins class="adsbygoogle" data-ad-format="leaderboard" style="display:block"></ins>
  </div>

  {heroArticle && (
    <section class="homepage-hero">
      <article class="article-card article-card--hero">
        <div class="card-image">
          <img
            src={heroArticle.image || `/images/${heroArticle.slug}.webp`}
            alt={heroArticle.title}
            loading="eager"
            width="800" height="450"
            onerror="this.src='/images/placeholder.webp'"
          />
        </div>
        <div class="card-body">
          <div class="card-category">{heroArticle.category || 'Featured'}</div>
          <h2 class="card-title" style="font-size: 28px;">
            <a href={`/${heroArticle.slug}`}>{heroArticle.title}</a>
          </h2>
          <p class="card-excerpt">{heroArticle.excerpt}</p>
          <div class="card-meta">
            <span>{heroArticle.author}</span>
            <span>{new Date(heroArticle.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
          </div>
        </div>
      </article>

      <div class="sidebar-stack">
        {featuredArticles.map(article => (
          <article class="article-card article-card--compact" style="display:flex; gap: 12px; padding: 12px; background: white; border-radius: 4px; margin-bottom: 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.08);">
            <img
              src={`/images/${article.slug}.webp`}
              alt={article.title}
              loading="lazy"
              width="80" height="60"
              style="width:80px; height:60px; object-fit:cover; border-radius:4px; flex-shrink:0;"
              onerror="this.src='/images/placeholder.webp'"
            />
            <div>
              <div class="card-category" style="font-size:10px;">{article.category}</div>
              <a href={`/${article.slug}`} style="font-family:'Merriweather',serif; font-size:14px; font-weight:700; color:#1a1a2e; text-decoration:none; line-height:1.3; display:block;">
                {article.title}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- Mid-page Ad -->
  <div class="ad-unit ad-unit--leaderboard" style="margin: 24px 0;">
    <ins class="adsbygoogle" data-ad-format="leaderboard" style="display:block"></ins>
  </div>

  <!-- Latest Articles Grid -->
  <section>
    <h2 style="font-family:'Merriweather',serif; font-size:22px; color:#1a1a2e; margin-bottom:20px; padding-bottom:8px; border-bottom:3px solid #c0392b;">
      Latest Articles
    </h2>
    <div class="articles-grid">
      {latestArticles.map(article => (
        <article class="article-card">
          <div class="card-image">
            <img
              src={`/images/${article.slug}.webp`}
              alt={article.title}
              loading="lazy"
              width="400" height="300"
              onerror="this.src='/images/placeholder.webp'"
            />
          </div>
          <div class="card-body">
            <div class="card-category">{article.category}</div>
            <h3 class="card-title"><a href={`/${article.slug}`}>{article.title}</a></h3>
            <p class="card-excerpt">{article.excerpt}</p>
            <div class="card-meta">
              <span>{article.author}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>
